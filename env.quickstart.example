# Скопируйте в файл .env в корне проекта (рядом с run_excel_jurisdiction.py)
#
# --- Рекомендуется для точного определения мирового суда по адресу ---
YANDEX_GEO_KEY=
DADATA_TOKEN=
# Желательно вместе с YANDEX: при 403 Геокодера Яндекса включается DaData (прямой и обратный геокод).
# Опционально: DaData Clean API для нормализации адреса перед поиском
# DADATA_SECRET=

# --- База списка судов (по умолчанию SQLite, менять не обязательно) ---
# COURTS_DB_BACKEND=sqlite
# Для PostgreSQL со списком судов: COURTS_DB_BACKEND=postgres и PG_DSN=...

# --- Полигоны на карте (опционально; без этого работает район + геокод) ---
# Рекомендуется отдельная переменная (не путается со списком судов):
# COURTS_SPATIAL_BACKEND=postgis
# PG_DSN=postgresql://postgres:postgres@localhost:5432/courts
# Устаревший вариант: COURTS_DB_BACKEND=postgis

# Не использовать fallback GISmap-зон в PostGIS (только классическая court_districts):
# POSTGIS_SKIP_GISMAP_ZONES=1
